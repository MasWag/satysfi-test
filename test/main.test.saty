@require: option
@import: lib/spy
@import: ../src/expect
@import: ../src/test

@import: integration.test
@import: test-case.test
@import: test-report-maker.test

open Test in
% We cannot use Expect because it's the very test subject!
let assert b = if b then ExpectResult.pass else  ExpectResult.fail `failure` in
describe `satysfi-test` [
  describe `Spy` [
    it `was-run is false initially` (fun () -> (
      let spy = Spy.make () in
      spy |> Spy.was-run |> Expect.is-false
    ));

    it `was-run is true when test-fun is called` (fun () -> (
      let spy = Spy.make () in
      let _ = (spy |> Spy.get-spy) () in
      spy |> Spy.was-run |> Expect.is-true
    ));
  ];

  describe `Test` [
    it `test calls test body` (fun () -> (
      let spy = Spy.make () in
      let _ = test `Mock test case` (spy |> Spy.get-spy) |> run in
      spy |> Spy.was-run |> Expect.is-true
    ));

    it `describe calls all test cases` (fun () -> (
      let (spy1, spy2) = (Spy.make (), Spy.make ()) in
      let _ = describe `Multiple test cases` [
        it `Test case 1` (spy1 |> Spy.get-spy);
        describe `Nested describe` [
          it `Test case 2` (spy2 |> Spy.get-spy);
        ]
      ] |> run in
      ((spy1 |> Spy.was-run) && (spy2 |> Spy.was-run))
      |> Expect.is-true
    ));
  ];

  % We cannot use Expect because it's the very test subject!
  describe `Expect` [
    it `always-pass` (fun () -> (
      Expect.always-pass|> ExpectResult.is-pass |> assert
    ));

    it `always-fail` (fun () -> (
      Expect.always-fail |> ExpectResult.is-pass |> (not) |> assert
    ));

    it `true passes when true given` (fun () -> (
      Expect.is-true true |> ExpectResult.is-pass |> assert
    ));

    it `true fails when false given` (fun () -> (
      Expect.is-true false |> ExpectResult.is-pass |> (not) |> assert
    ));

    it `false passes when false given` (fun () -> (
      Expect.is-false false |> ExpectResult.is-pass |> assert
    ));

    it `false fails when true given` (fun () -> (
      Expect.is-false true |> ExpectResult.is-pass |> (not) |> assert
    ));
  ];

  test-case-tests;
  test-report-maker-tests;

  integration-tests;

  describe `Enhanced Expect` [
    it `pass always passes` (fun () -> (
      Expect.pass |> ExpectResult.is-pass |> assert
    ));

    it `fail always fails with a message` (fun () -> (
      Expect.is-false (Expect.fail `bad` |> ExpectResult.is-pass)
    ));

    it `fail carries the message` (fun () -> (
      let result = Expect.fail `my failure reason` in
      let is-ok = ExpectResult.cases (|
        pass = (fun () -> false);
        fail = (fun msg -> (
          match msg with
          | Some m -> m |> string-same `my failure reason`
          | None -> false
        ));
      |) result in
      is-ok |> assert
    ));

    it `on-fail replaces message on failure` (fun () -> (
      let result = Expect.on-fail `replacement` (Expect.fail `original`) in
      let is-ok = ExpectResult.cases (|
        pass = (fun () -> false);
        fail = (fun msg -> (
          match msg with
          | Some m -> m |> string-same `replacement`
          | None -> false
        ));
      |) result in
      is-ok |> assert
    ));

    it `on-fail preserves pass result` (fun () -> (
      Expect.on-fail `replaced` Expect.pass |> ExpectResult.is-pass |> assert
    ));

    it `all with empty list fails` (fun () -> (
      Expect.is-false (Expect.all [] () |> ExpectResult.is-pass)
    ));

    it `all with passing tests succeeds` (fun () -> (
      Expect.all [ fun _ -> Expect.pass; fun _ -> Expect.pass ] () |> ExpectResult.is-pass |> assert
    ));

    it `all with failing test returns first failure` (fun () -> (
      Expect.all [ fun _ -> Expect.pass; fun _ -> Expect.fail `third` ] () |> ExpectResult.is-pass |> (not) |> assert
    ));

    it `equal-bool true true passes` (fun () -> (
      Expect.equal-bool true true |> ExpectResult.is-pass |> assert
    ));

    it `equal-bool false false passes` (fun () -> (
      Expect.equal-bool false false |> ExpectResult.is-pass |> assert
    ));

    it `equal-bool true false fails` (fun () -> (
      ExpectResult.is-fail (Expect.equal-bool true false) |> assert
    ));

    it `equal-bool false true fails` (fun () -> (
      ExpectResult.is-fail (Expect.equal-bool false true) |> assert
    ));

    it `not-equal-bool true false passes` (fun () -> (
      Expect.not-equal-bool true false |> ExpectResult.is-pass |> assert
    ));

    it `not-equal-bool false true passes` (fun () -> (
      Expect.not-equal-bool false true |> ExpectResult.is-pass |> assert
    ));

    it `not-equal-bool true true fails` (fun () -> (
      ExpectResult.is-fail (Expect.not-equal-bool true true) |> assert
    ));

    it `equal-int 3 3 passes` (fun () -> (
      Expect.equal-int 3 3 |> ExpectResult.is-pass |> assert
    ));

    it `equal-int 3 4 fails with message containing expected and got` (fun () -> (
      let result = Expect.equal-int 3 4 in
      let is-ok = ExpectResult.cases (|
        pass = (fun () -> false);
        fail = (fun msg -> (
          match msg with
          | Some m -> m |> string-same `Expect.equal-int failed: expected 3, got 4`
          | None -> false
        ));
      |) result in
      is-ok |> assert
    ));

    it `not-equal-int 3 4 passes` (fun () -> (
      Expect.not-equal-int 3 4 |> ExpectResult.is-pass |> assert
    ));

    it `not-equal-int 3 3 fails` (fun () -> (
      ExpectResult.is-fail (Expect.not-equal-int 3 3) |> assert
    ));

    it `equal-string matches identical strings` (fun () -> (
      Expect.equal-string `abc` `abc` |> ExpectResult.is-pass |> assert
    ));

    it `equal-string differs produces a failure with a message` (fun () -> (
      let result = Expect.equal-string `abc` `abd` in
      let is-ok = ExpectResult.cases (|
        pass = (fun () -> false);
        fail = (fun msg -> (
          match msg with
          | Some _ -> true
          | None -> false
        ));
      |) result in
      is-ok |> assert
    ));

    it `not-equal-string differs` (fun () -> (
      Expect.not-equal-string `abc` `abd` |> ExpectResult.is-pass |> assert
    ));

    it `not-equal-string matches` (fun () -> (
      let result = Expect.equal-string `abc` `abc` in
      let is-ok = ExpectResult.cases (|
        pass = (fun () -> false);
        fail = (fun msg -> (
          match msg with
          | Some m -> m |> string-same `Expect.equal-string failed: expected "abc", got "abc"`
          | None -> false
        ));
      |) result in
      is-ok |> assert
    ));

    it `is-true works as before` (fun () -> (
      Expect.is-true true |> ExpectResult.is-pass |> assert
    ));

    it `is-false works as before` (fun () -> (
      Expect.is-false false |> ExpectResult.is-pass |> assert
    ));

    it `always-pass works as before` (fun () -> (
      Expect.always-pass |> ExpectResult.is-pass |> assert
    ));

    it `always-fail works as before` (fun () -> (
      ExpectResult.is-fail (Expect.always-fail) |> assert
    ));
  ];

  describe `Enhanced Expect report test` [
    it `failure message appears in report` (fun () -> (
      let report = test `expect-fails-with-message` (fun () -> (
        Expect.fail `custom failure reason`
      )) |> TestCase.run |> TestReportMaker.make-report in
      let is-ok = report
      |> string-same `Test summary : 1 run, 0 success, 1 fail
  
Test run report
- expect-fails-with-message -> FAIL
  custom failure reason
  
`# in
      is-ok |> assert
    ));
  ];

 ] |> Test.run